@model Aromo.Models.Catalogue
@{
    ViewData["Title"] = "Редакция на каталог";
}

<div class="container mt-4">
    <h2 class="fw-bold text-gold mb-4">✏️ Редакция на каталог</h2>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-gold">Запази</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Назад</a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
