@model Aromo.Models.Catalogue
@{
    ViewData["Title"] = "Каталог";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-gold">📦 @Model.Name</h2>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-gold">
            ✏️ Редакция
        </a>
    </div>

    @if (!Model.Perfumes.Any())
    {
        <p class="text-muted">Каталогът е празен.</p>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var perfume in Model.Perfumes)
            {
                var imageUrls = (Dictionary<int, string>)ViewBag.ImageUrls;
                var imageUrl = imageUrls.ContainsKey(perfume.Id) ? imageUrls[perfume.Id] : "/images/default.png";
                 
                <div class="list-group-item d-flex align-items-center gap-3" style="background-color:black">
                    <img src="@imageUrl"
                         onerror="this.src='/images/default.png'"
                         class="rounded shadow-sm"
                         style="width:60px;height:60px;object-fit:cover;" />

                    <div class="flex-grow-1">
                        <a asp-area=""
                           asp-controller="Perfumes"
                           asp-action="Details"
                           asp-route-id="@perfume.Id"
                           class="fw-bold text-decoration-none">
                            @perfume.Name
                        </a>

                        <div class="text-muted small">
                            @perfume.Original · @perfume.Volume ml
                        </div>
                    </div>

                    <div class="fw-bold text-gold">
                        €@perfume.Price
                    </div>
                </div>
            }
        </div>
    }

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Назад</a>
    </div>
</div>
