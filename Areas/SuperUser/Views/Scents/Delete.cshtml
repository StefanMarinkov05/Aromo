@model Aromo.Models.Scent

@{
    ViewData["Title"] = "Изтриване на аромат";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">⚠ Изтриване на аромат</h4>
                </div>

                <div class="card-body">
                    <p class="text-muted">
                        Това действие е <strong>необратимо</strong>.
                    </p>

                    <dl class="row">
                        <dt class="col-sm-4">Аромат</dt>
                        <dd class="col-sm-8 fw-semibold">
                            @Model.Name
                        </dd>
                    </dl>

                    <form asp-controller="Seasons" asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-between">
                            <a asp-controller="PerfumeFeatures"
                               asp-action="Index"
                               class="btn btn-outline-secondary">
                                Отказ
                            </a>

                            <button type="submit" class="btn btn-danger px-4">
                                Изтрий
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
