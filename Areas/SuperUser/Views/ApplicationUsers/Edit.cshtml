@model Aromo.Models.ApplicationUser

@{
    ViewData["Title"] = "Редактиране на потребител";
}

<div class="container mt-5">

    <div class="card shadow-lg border-secondary"
         style="background: linear-gradient(145deg, #2b2b2b, #1f1f1f); color: #e6e6e6;">

        <div class="card-header bg-dark text-warning fw-bold rounded-top-3">
            <h3 class="mb-0"><i class="bi bi-person-circle"></i> @ViewData["Title"]</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Име</label>
                    <input asp-for="FirstName" class="form-control bg-dark text-light border-secondary" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Фамилия</label>
                    <input asp-for="LastName" class="form-control bg-dark text-light border-secondary" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Имейл</label>
                    <input asp-for="Email" class="form-control bg-dark text-light border-secondary" required />
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-light btn-lg shadow-sm">
                        <i class="bi bi-arrow-left"></i> Отказ
                    </a>
                    <button type="submit" class="btn btn-warning btn-lg fw-bold shadow-sm">
                        <i class="bi bi-save"></i> Запази
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
