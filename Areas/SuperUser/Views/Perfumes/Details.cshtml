@model Aromo.Models.Perfume

@{
    ViewData["Title"] = "Детайли за парфюм";
}

<div class="container py-5">
    <div class="row g-5 align-items-start">

        <div class="col-lg-5">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <img src="@ViewBag.ImageUrl"
                     onerror="this.src='@Url.Content("~/images/default.png")'"
                     onload="this.onerror=null;"
                     style="height:520px; object-fit:cover;"
                     class="w-100" />
            </div>
        </div>

        <div class="col-lg-7">
            <h1 class="fw-bold text-gold mb-2">
                @Model.Name
            </h1>

            <h5 class="text-muted mb-3">
                @Model.Brand.Name
            </h5>

            @if (!string.IsNullOrEmpty(Model.Original))
            {
                <p class="fst-italic text-warning mb-4">
                    Вдъхновен от: @Model.Original
                </p>
            }

            <div class="mb-4">
                <span class="badge bg-dark me-2">
                    @Model.Gender.Name
                </span>
                <span class="badge bg-secondary">
                    @Model.Season.Name
                </span>
            </div>

            <div class="mb-4">
                <p>
                    <strong>Връхни нотки:</strong><br />
                    @string.Join(", ", Model.TopScents.Select(s => s.Name))
                </p>

                <p>
                    <strong>Сърцеви нотки:</strong><br />
                    @string.Join(", ", Model.HeartScents.Select(s => s.Name))
                </p>

                <p>
                    <strong>Базови нотки:</strong><br />
                    @string.Join(", ", Model.BaseScents.Select(s => s.Name))
                </p>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <strong>Обем:</strong> @(Model.Volume)mL
                </div>
                <div class="col-md-6">
                    <strong>Цена:</strong> €@Model.Price.ToString("0.00").
                </div>
            </div>
 <hr />

            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-light">
                    ✏️ Редакция
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    ⬅ Назад
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: #d4af37;
    }
</style>
